FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    iputils-ping curl dnsutils netcat-openbsd mtr \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-agent.txt .
RUN pip install --no-cache-dir -r requirements-agent.txt

COPY agent/ ./agent/
COPY version.py .

# Optional: --listen-port enables this agent as an internal probe target
# Example: docker run nsr-agent --server x.x.x.x --port 9192 --node-id xxx --token xxx --listen-port 9192
ENTRYPOINT ["python", "-m", "agent.main"]
